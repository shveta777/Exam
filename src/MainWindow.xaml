<Window x:Class="Exam.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Exam"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <DataGrid x:Name="PhoneGrid" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="0,130,0,183">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Марка"
                                    Binding="{Binding Marka}"/>
                <DataGridTextColumn Header="Модель"
                                    Binding ="{Binding Model}"/>
                <DataGridTextColumn Header="Цена"
                                    Binding="{Binding Price}"/>
            </DataGrid.Columns>
        </DataGrid>
        <TextBox x:Name="PhoneTextBox" HorizontalAlignment="Left" Margin="155,62,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120"/>
        <TextBlock HorizontalAlignment="Left" Margin="0,62,0,0" TextWrapping="Wrap" Text="Введите размер массива:" VerticalAlignment="Top"/>
        <Button x:Name="NewPhone" Content="Создать" HorizontalAlignment="Left" Margin="319,62,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.5,0.5" Height="26" Width="73">
            <Button.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="0.765"/>
                    <TranslateTransform/>
                </TransformGroup>
            </Button.RenderTransform>
        </Button>
        <Button x:Name="SortPhone" Content="Отсортировать" HorizontalAlignment="Left" Margin="423,62,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.5,0.5" Height="29" Width="91">
            <Button.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="0.765"/>
                    <TranslateTransform/>
                </TransformGroup>
            </Button.RenderTransform>
        </Button>

    </Grid>
    <Button Height="29" Width="91" VerticalAlignment="Top" RenderTransformOrigin="0.5,0.5" x:Name="SortPhone_Копировать" Margin="423,62,0,0" HorizontalAlignment="Left" Content="Отсортировать">
        <Button.RenderTransform
>
            <TransformGroup
>
                <ScaleTransform
/>
                <SkewTransform
/>
                <RotateTransform
                Angle="0.765"/>
                <TranslateTransform
/>
            </TransformGroup>
        </Button.RenderTransform>

    </Button>
    <Button Content="ButtonNoSort" HorizontalAlignment="Left" Margin="547,62,0,0" VerticalAlignment="Top" Height="31" Width="59"/>
</Window>
